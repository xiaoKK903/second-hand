{
    "compilerOptions": {
        "target": "es5",
        "module": "commonjs",
        "sourceMap": true,
        "lib": ["es2015", "es2016", "dom"],
        "skipLibCheck": true,
        "noImplicitAny": false,
        "strict": false,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true
    },
    "include": ["controller", "routes", "service", "service", "model", "config"],
    "exclude": ["node_modules", "dist"]
}